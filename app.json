{
  "expo": {
    "name": "AI健康管家",
    "slug": "ai-health-manager",
    "version": "1.0.0",
    "icon": "./assets/logo_1.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aihealthmanager.app",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "需要蓝牙权限以连接手环并读取心率数据",
        "NSBluetoothPeripheralUsageDescription": "需要蓝牙权限以连接手环并读取心率数据"
      }
    },
    "android": {
      "package": "com.aihealthmanager.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_1.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "CAMERA",
        "NOTIFICATIONS",
        "RECORD_AUDIO",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "允许访问相机以拍摄药盒"
        }
      ],
      [
        "expo-notifications",
        {}
      ]
    ],
    "extra": {
      "CLOUD_API_BASE_URL": "http://10.206.179.103:4000",
      "TONGUE_API_BASE_URL": "http://127.0.0.1:5000",
      "SILICONFLOW_API_KEY": "sk-mhlnnwihlysymqhqbnnqcrbnqhmmmtofvejqfndfoivbqnjj"
    }
  }
}

